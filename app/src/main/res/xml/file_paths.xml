<?xml version="1.0" encoding="utf-8"?>
<!-- FileProvider path config. We only ever share the exported zip from cacheDir/log-exports;
     the raw filesDir/logs tree is never exposed directly. -->
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <cache-path
        name="log-exports"
        path="log-exports/" />
</paths>
